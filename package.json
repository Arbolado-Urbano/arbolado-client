{
  "name": "arboles-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite preview",
    "dev": "vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "lint": "eslint",
    "typecheck": "tsc",
    "docker:pull": "docker compose -f ./docker-compose.yml pull",
    "docker:up": "docker compose -p arbolado-client -f ./docker-compose.yml up -d",
    "docker:down": "docker compose -p arbolado-client down"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@fortawesome/fontawesome-free": "7.2.0",
    "@popperjs/core": "2.11.8",
    "@types/bootstrap": "5.2.10",
    "@types/cloudflare-turnstile": "0.2.2",
    "@types/leaflet": "1.9.21",
    "@types/leaflet.markercluster": "1.5.6",
    "@typescript-eslint/parser": "8.59.0",
    "bootstrap": "5.3.8",
    "eslint": "10.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.5.0",
    "leaflet": "1.9.4",
    "leaflet.markercluster": "1.5.3",
    "sass": "1.99.0",
    "typescript": "6.0.3",
    "vite": "8.0.10"
  }
}
