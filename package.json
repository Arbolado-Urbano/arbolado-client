{
  "name": "arboles-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.15.0"
  },
  "packageManager": "npm@11.15.0",
  "scripts": {
    "start": "vite preview",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "lint": "eslint",
    "typecheck": "tsc",
    "docker:pull": "docker compose -f ./docker-compose.yml pull",
    "docker:up": "docker compose -p arbolado-client -f ./docker-compose.yml up -d",
    "docker:down": "docker compose -p arbolado-client down"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "7.2.0",
    "@popperjs/core": "2.11.8",
    "bootstrap": "5.3.8",
    "maplibre-gl": "5.24.0",
    "pmtiles": "4.4.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bootstrap": "5.2.10",
    "@types/cloudflare-turnstile": "0.2.2",
    "@typescript-eslint/parser": "8.59.4",
    "eslint": "10.4.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "sass": "1.99.0",
    "typescript": "6.0.3",
    "vite": "8.0.13"
  }
}